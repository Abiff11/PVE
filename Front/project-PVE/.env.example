# Variables de entorno para el Frontend (React + Vite)
# Copia este archivo a .env en Front/project-PVE/

# ============================================
# Desarrollo local
# ============================================

# URL del backend (el frontend se conecta a esta URL)
VITE_API_URL=http://localhost:3000

# ============================================
# Producción
# ============================================
# Para producción, NO uses .env
# El valor de VITE_API_URL se configura en el build
# mediante el workflow de GitHub Actions (secrets.PRODUCT_API_URL)
