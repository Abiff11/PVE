# Variables de entorno para Docker
# Copia este archivo a .env y configura los valores

# ============================================
# Desarrollo local
# ============================================
# Descomenta estas líneas para desarrollo local

# DB_USER=pve_user
# DB_PASSWORD=tu_password_seguro
# DB_NAME=pve_db
# DB_PORT=5432
# JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro_min_64_caracteres
# FRONTEND_URL=http://localhost:5173
# API_URL=http://localhost:3000
# VITE_API_URL=http://localhost:3000

# ============================================
# Producción (Render)
# ============================================
# Configura estas variables para producción:

# Base de datos (Render PostgreSQL)
# DB_USER=tu_usuario_render
# DB_PASSWORD=tu_password_render
# DB_NAME=tu_db_render
# DB_PORT=5432
# DB_HOST=tu_host_render

# JWT (genera uno seguro)
# JWT_SECRET=tu_jwt_secret_muy_largo_y_seguro_min_64_caracteres

# Frontend URL (para CORS)
# FRONTEND_URL=https://pve-frontend.onrender.com

# API URL (para el frontend en build)
# API_URL=https://pve-backend-latest.onrender.com
# VITE_API_URL=https://pve-backend-latest.onrender.com
